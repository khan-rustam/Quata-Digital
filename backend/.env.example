# --- Core ---
ENVIRONMENT=production
PROJECT_NAME="QUATA Digital API"
API_PREFIX=/api/v1
# Public origin where /uploads/... will be served from.
PUBLIC_BASE_URL=https://quatadigital.com

# Public origin of the marketing site (used in password-reset emails, etc.)
FRONTEND_URL=https://quatadigital.com

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-with-a-very-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# --- Database ---
# Default: SQLite (zero config for dev). Swap to Postgres in prod.
DATABASE_URL=sqlite:///./quata.db
# DATABASE_URL=postgresql+psycopg://quata:strong-password@localhost:5432/quata

# --- Schema management ---
# Dev: AUTO_CREATE_TABLES=true creates missing tables on boot.
# Prod: set to false and run `alembic upgrade head` instead.
AUTO_CREATE_TABLES=true

# --- CORS ---
BACKEND_CORS_ORIGINS=["https://quatadigital.com","https://www.quatadigital.com","https://2025quata.quatadigital.com","http://localhost:3000"]

# --- Seeding ---
# Set SEED_ON_STARTUP=false after first deploy.
SEED_ON_STARTUP=true
DEFAULT_ADMIN_EMAIL=admin@quatadigital.com
DEFAULT_ADMIN_PASSWORD=ChangeMe!2026

# --- File uploads (local disk on the VPS) ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=25

# --- Email (production: SMTP2GO) ---
# console: prints to stdout (dev). smtp: real send. disabled: silent.
EMAIL_BACKEND=smtp
SMTP_HOST=mail.smtp2go.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM="QUATA Digital <noreply@quatadigital.com>"
# Comma-separated internal recipients for partner submissions, contact forms, etc.
EMAIL_NOTIFY_TO=info@quatadigital.com

# --- i18n ---
DEFAULT_LOCALE=en
SUPPORTED_LOCALES=["en"]

# --- Account security ---
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_MINUTES=15
PASSWORD_RESET_TTL_MINUTES=30
PASSWORD_MIN_LENGTH=10

# --- 2FA ---
TOTP_ISSUER="QUATA Digital"

# --- Rate limits ---
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_PUBLIC_FORM=20/minute
RATE_LIMIT_PASSWORD_RESET=5/hour

# --- Device webhook HMAC (set true to enforce in addition to per-device token) ---
DEVICE_REQUIRE_SIGNATURE=false
DEVICE_HMAC_HEADER=X-Device-Signature
DEVICE_HMAC_TIMESTAMP_HEADER=X-Device-Timestamp
DEVICE_HMAC_SKEW_SECONDS=300

# --- Observability ---
# SENTRY_DSN=https://...
# SENTRY_ENV=production
LOG_FORMAT=json
